# NVIDIA API (build.nvidia.com)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter (ücretsiz Nemotron — openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# Sentinel Hub (sentinel-hub.com — ücretsiz trial)
SENTINEL_HUB_CLIENT_ID=your-client-id
SENTINEL_HUB_CLIENT_SECRET=your-client-secret

# JWT
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production

# Database (SQLite default, PostgreSQL için: postgresql+asyncpg://user:pass@host/db)
DATABASE_URL=sqlite:///./tespet.db
